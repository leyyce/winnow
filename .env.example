# .env.example
# Copy to .env and fill in your values.
# .env is gitignored and excluded from Docker image builds via .dockerignore.

# ── Compose behaviour ─────────────────────────────────────────────────────────
# Uncomment on developer machines so `docker compose` defaults to the dev stack.
# Remove or leave commented on servers where compose.yaml (prod) is the default.
# COMPOSE_FILE=compose.dev.yaml

# ── Application ───────────────────────────────────────────────────────────────
APP_NAME=winnow
ENVIRONMENT=development

# ── Domain ────────────────────────────────────────────────────────────────────
# Dev:  service is available at https://{APP_DOMAIN}.localhost
APP_DOMAIN=winnow.localhost
PROBLEM_BASE_URI="https://${APP_DOMAIN}"

# ── PostgreSQL (individual components — compose.yaml and compose.dev.yaml use
#    these same variables to configure the `db` service).
#    DATABASE_URL is assembled from these automatically in app/core/config.py.
# ─────────────────────────────────────────────────────────────────────────────
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=winnow
POSTGRES_USER=winnow
# Generate a strong password: openssl rand -hex 32
POSTGRES_PASSWORD=changeme-generate-with-openssl-rand-hex-32

# ── Let's Encrypt (production only) ───────────────────────────────────────────
# Caddy uses this to register with ACME and receive cert expiry warnings.
ACME_EMAIL=admin@example.com

# ── App secrets ───────────────────────────────────────────────────────────────
# Generate a strong key: openssl rand -hex 32
SECRET_KEY=changeme-generate-with-openssl-rand-hex-32
